PORT=5000
NODE_ENV=development
DEPLOYMENT=local
DATABASE_URL=postgres://username:password@your-neon-host/dbname?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
GRAPH_API_VERSION=v24.0

# OAuth Config
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/api/oauth/facebook/callback
FACEBOOK_SCOPES=public_profile,pages_show_list,pages_read_engagement,pages_manage_posts

# Instagram OAuth (defaults to Facebook app id/secret if omitted)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:5000/api/oauth/instagram/callback
INSTAGRAM_SCOPES=instagram_basic,instagram_content_publish,pages_show_list,pages_read_engagement,pages_manage_posts

# Threads OAuth
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=http://localhost:5000/api/oauth/threads/callback
THREADS_SCOPES=threads_basic,threads_content_publish

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/oauth/linkedin/callback
LINKEDIN_SCOPES=openid profile email w_member_social r_profile_basicinfo r_verify

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:5000/api/oauth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,user.info.profile,user.info.stats,video.list,video.upload,video.publish

# X (Twitter) OAuth
X_CLIENT_ID=
X_CLIENT_SECRET=
# Optional aliases (if you copied from X Developer Portal naming):
# X_OAUTH_2_0_CLIENT_ID=
# X_OAUTH_2_0_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:5000/api/oauth/x/callback
X_SCOPES=tweet.read tweet.write users.read offline.access

# YouTube OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Optional aliases used by some Google Console naming conventions:
# GOOGLE_YOUTUBE_OAUTH_SOCIALSYNC_CLIENT_ID=
# GOOGLE_YOUTUBE_OAUTH_SOCIALSYNC_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/oauth/youtube/callback
YOUTUBE_SCOPES=openid profile email https://www.googleapis.com/auth/youtube.readonly https://www.googleapis.com/auth/youtube.upload

# Pinterest OAuth
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
# Optional aliases accepted by backend:
# PINTEREST_APP_ID=
# PINTERST_APP_ID=
# PINTEREST_APP_SECRET=
# Optional direct user token for custom integrations:
# PINTEREST_ACCESS_TOKEN=
PINTEREST_REDIRECT_URI=http://localhost:5000/api/oauth/pinterest/callback
PINTEREST_SCOPES=user_accounts:read,boards:read,pins:read,pins:write

# Shared secret for scheduler worker endpoint auth
WORKER_SHARED_SECRET=replace-with-a-strong-shared-secret


# Firebase Configuration
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Firebase Admin Service Account (Required for backend storage)
# You can get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=