{
  "name": "paintoutlet-ai-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express MVC backend for AI-powered social post scheduling with Neon.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "check": "powershell -NoProfile -Command \"Get-ChildItem -Recurse -Filter *.js | ForEach-Object { node --check $_.FullName }\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "ws": "^8.18.0"
  }
}
